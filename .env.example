# ─────────────────────────────────────────────────────────────
# Database — Postgres with the pgvector extension enabled
# ─────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/unified?schema=public"

# ─────────────────────────────────────────────────────────────
# Clerk auth (enable Google + Microsoft as social connections)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/dashboard"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/dashboard"

# ─────────────────────────────────────────────────────────────
# App base URL (used to build OAuth redirect URIs)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─────────────────────────────────────────────────────────────
# Token encryption — 32-byte key, base64 encoded
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# ─────────────────────────────────────────────────────────────
TOKEN_ENCRYPTION_KEY="base64-encoded-32-byte-key"

# ─────────────────────────────────────────────────────────────
# Gmail API (Google Cloud OAuth client — Web application)
#   Authorized redirect URI: {APP_URL}/api/connect/gmail/callback
# ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─────────────────────────────────────────────────────────────
# Microsoft Graph (Azure AD app registration)
#   Redirect URI: {APP_URL}/api/connect/outlook/callback
# ─────────────────────────────────────────────────────────────
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
MICROSOFT_TENANT_ID="common"

# ─────────────────────────────────────────────────────────────
# LLM providers
# ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# ─────────────────────────────────────────────────────────────
# Inngest (background sync jobs)
# ─────────────────────────────────────────────────────────────
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""
